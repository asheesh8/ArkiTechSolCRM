generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  DEV
  MEMBER
}

enum LeadStatus {
  NEW
  SAVED
  CALLED
  MEETING_BOOKED
  NOT_INTERESTED
  FOLLOW_UP
  CLOSED
}

enum LeadPriority {
  STANDARD
  PRIORITY
  FAVORITE
}

enum CallOutcome {
  NO_ANSWER
  LEFT_VOICEMAIL
  CALLED
  NOT_INTERESTED
  FOLLOW_UP
  MEETING_BOOKED
  CLOSED
}

enum NoteType {
  GENERAL
  FOLLOW_UP
  MEETING
}

enum LeadExclusionReason {
  ARCHIVED
  DECLINED
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String?
  role         Role       @default(MEMBER)
  leads        Lead[]     @relation("AssignedLeads")
  callNotes    CallNote[]
  scrapeUsages ScrapeUsage[]
  staffSessions StaffSession[]
  noteCabinets NoteCabinet[]
  notePages    NotePage[]
  notePresences NotePresence[]
  devWorkRequests WorkRequest[] @relation("AssignedDevWorkRequests")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model StaffSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Lead {
  id                         String      @id @default(cuid())
  businessName               String
  category                   String?
  phone                      String?
  email                      String?
  website                    String?
  address                    String?
  city                       String?
  state                      String?
  googlePlaceId              String?     @unique
  googleMapsUrl              String?
  googleRating               Float?
  googleReviewCount          Int?
  status                     LeadStatus  @default(NEW)
  priority                   LeadPriority @default(STANDARD)
  websiteScore               Int?
  pageSpeedPerformance       Int?
  pageSpeedAccessibility     Int?
  pageSpeedSEO               Int?
  pageSpeedBestPractices     Int?
  notes                      String?
  assignedToId               String?
  assignedTo                 User?       @relation("AssignedLeads", fields: [assignedToId], references: [id], onDelete: SetNull)
  callNotes                  CallNote[]
  audits                     Audit[]
  client                     Client?
  receptionistConversations ReceptionistConversation[]
  createdAt                  DateTime    @default(now())
  updatedAt                  DateTime    @updatedAt

  @@index([status])
  @@index([priority])
  @@index([city, state])
  @@index([category])
  @@index([assignedToId])
}

model CallNote {
  id           String       @id @default(cuid())
  leadId       String
  userId       String
  note         String
  noteType     NoteType     @default(GENERAL)
  callOutcome  CallOutcome
  followUpDate DateTime?
  createdAt    DateTime     @default(now())
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([userId])
  @@index([noteType])
  @@index([followUpDate])
}

model Audit {
  id                       String   @id @default(cuid())
  leadId                   String?
  url                      String
  strategy                 String   @default("mobile")
  performance              Int?
  accessibility            Int?
  seo                      Int?
  bestPractices            Int?
  firstContentfulPaint     String?
  largestContentfulPaint   String?
  speedIndex               String?
  totalBlockingTime        String?
  cumulativeLayoutShift    String?
  opportunities            Json?
  createdAt                DateTime @default(now())
  lead                     Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([url])
}

model LeadExclusion {
  id            String              @id @default(cuid())
  googlePlaceId String              @unique
  businessName  String
  reason        LeadExclusionReason
  createdAt     DateTime            @default(now())

  @@index([reason])
}

model ScrapeUsage {
  id        String   @id @default(cuid())
  userId    String
  dateKey   String
  monthKey  String
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@index([monthKey])
  @@index([userId, monthKey])
}

// ─── Client Portal ───────────────────────────────────────────────────────────

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  ACTIVE
  CANCELLED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum WorkStatus {
  OPEN
  IN_PROGRESS
  REVIEW
  COMPLETED
  CANCELLED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  ANNUAL
  ONE_TIME
}

model Client {
  id               String    @id @default(cuid())
  leadId           String?   @unique
  name             String
  email            String    @unique
  phone            String?
  businessName     String
  passwordHash     String?
  setupToken       String?   @unique
  setupExpiry      DateTime?
  sessionToken     String?   @unique
  sessionExpiry    DateTime?
  stripeCustomerId String?
  avatarUrl        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  lead         Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contracts    Contract[]
  invoices     Invoice[]
  workRequests WorkRequest[]

  @@index([email])
}

model Contract {
  id            String         @id @default(cuid())
  clientId      String
  planName      String
  lineItems     Json
  subtotal      Float
  tax           Float          @default(0)
  total         Float
  billingCycle  BillingCycle   @default(MONTHLY)
  status        ContractStatus @default(DRAFT)
  sentAt        DateTime?
  signedAt      DateTime?
  signatureData String?
  signToken     String?        @unique
  notes         String?
  documentKey   String?
  documentName  String?
  providerSignatureData String?
  providerSignedAt      DateTime?
  providerName          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([clientId])
  @@index([status])
}

model Invoice {
  id              String        @id @default(cuid())
  clientId        String
  contractId      String?
  stripeInvoiceId String?
  amount          Float
  status          InvoiceStatus @default(PENDING)
  dueDate         DateTime
  paidAt          DateTime?
  description     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contract Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
}

model WorkRequest {
  id                  String     @id @default(cuid())
  clientId            String
  title               String
  description         String?
  status              WorkStatus @default(OPEN)
  requestType         String     @default("CLIENT_REQUEST")
  priority            String     @default("NORMAL")
  estimateHours       Float?
  actualHours         Float?
  repositoryUrl       String?
  dueDate             DateTime?
  assignedDeveloperId String?
  staffNote           String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  client            Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedDeveloper User?      @relation("AssignedDevWorkRequests", fields: [assignedDeveloperId], references: [id], onDelete: SetNull)
  files             WorkFile[]

  @@index([clientId])
  @@index([status])
  @@index([assignedDeveloperId])
  @@index([dueDate])
}

model WorkFile {
  id            String   @id @default(cuid())
  workRequestId String
  name          String
  r2Key         String
  size          BigInt
  mimeType      String?
  createdAt     DateTime @default(now())

  workRequest WorkRequest @relation(fields: [workRequestId], references: [id], onDelete: Cascade)

  @@index([workRequestId])
}

// ─── AI Receptionist Archive ────────────────────────────────────────────────

model ReceptionistConversation {
  id                     String    @id @default(cuid())
  providerConversationId String    @unique
  agentId                String
  agentName              String?
  status                 String
  callSuccessful         String?
  callSuccessScore       Float?
  title                  String?
  summary                String?   @db.Text
  searchText             String?   @db.Text
  callerPhone            String?
  agentPhone             String?
  direction              String?
  initiationSource       String?
  mainLanguage           String?
  terminationReason      String?
  durationSecs           Int       @default(0)
  messageCount           Int       @default(0)
  startedAt              DateTime
  endedAt                DateTime?
  hasAudio               Boolean   @default(false)
  costFiat               Float?
  rating                 Float?
  sentimentLabel         String?
  metadata               Json?
  analysis               Json?
  initiationData         Json?
  tagIds                 String[]  @default([])
  internalNote           String?   @db.Text
  leadId                 String?
  detailStatus           String?
  detailSyncedAt         DateTime?
  syncedAt               DateTime  @default(now())
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  lead     Lead?                 @relation(fields: [leadId], references: [id], onDelete: SetNull)
  messages ReceptionistMessage[]

  @@index([agentId, startedAt])
  @@index([startedAt])
  @@index([status])
  @@index([callSuccessful])
  @@index([callerPhone])
  @@index([leadId])
}

model ReceptionistMessage {
  id             String   @id @default(cuid())
  conversationId String
  sequence       Int
  role           String
  message        String?  @db.Text
  timeInCallSecs Float?
  interrupted    Boolean  @default(false)
  sourceMedium   String?
  rawData        Json?
  createdAt      DateTime @default(now())

  conversation ReceptionistConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, sequence])
  @@index([conversationId])
  @@index([role])
}

model ReceptionistSyncState {
  agentId              String    @id
  lastIncrementalAt    DateTime?
  lastFullReconcileAt  DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

// ─── Analytics ───────────────────────────────────────────────────────────────

model PageView {
  id        String   @id @default(cuid())
  site      String
  path      String   @default("/")
  referrer  String?
  ipHash    String
  ua        String?
  createdAt DateTime @default(now())

  @@index([site])
  @@index([site, createdAt])
  @@index([createdAt])
}

// ─── Notes workspace ─────────────────────────────────────────────────────────
// A team-shared, AppFlowy-style docs area. Cabinets are the top-level "filing
// cabinets"; pages nest infinitely inside a cabinet via NotePage.parentId.

model NoteCabinet {
  id          String     @id @default(cuid())
  name        String     @default("New cabinet")
  icon        String     @default("📁")
  color       String     @default("blue")
  sortOrder   Int        @default(0)
  createdById String?
  createdBy   User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)
  pages       NotePage[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([sortOrder])
}

model NotePage {
  id          String      @id @default(cuid())
  cabinetId   String
  cabinet     NoteCabinet @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      NotePage?   @relation("PageTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    NotePage[]  @relation("PageTree")
  title       String      @default("Untitled")
  icon        String      @default("📄")
  content     String      @default("")
  sortOrder   Int         @default(0)
  createdById String?
  createdBy   User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)
  presences   NotePresence[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([cabinetId])
  @@index([parentId])
  @@index([cabinetId, parentId, sortOrder])
}

// Live "who's on this page" heartbeats for Google-Docs-style presence. Each
// client upserts its row on a short interval; stale rows (no recent heartbeat)
// are treated as gone and swept opportunistically.
model NotePresence {
  id        String   @id @default(cuid())
  pageId    String
  userId    String
  name      String
  updatedAt DateTime @updatedAt

  page NotePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pageId, userId])
  @@index([pageId])
  @@index([updatedAt])
}
